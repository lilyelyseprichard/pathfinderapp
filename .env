# Supabase project config. The publishable (anon) key is safe to ship in a client
# bundle — it's designed to be public and is scoped by your project's Row Level
# Security policies. Never put a secret/service_role key in an EXPO_PUBLIC_ var.
EXPO_PUBLIC_SUPABASE_URL=https://wyznnzgewwhdhgvzdhpb.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_P3XZYqGric0qx2hcZdOoZg_dWdSgFo_

# Auto-transcript feature (src/lib/transcribe.js) uses Groq's free Whisper API.
# That key is a real secret (unlike the Supabase key above), so don't put it
# here — this file is committed to git. Instead create a .env.local file
# (already gitignored) with:
#   EXPO_PUBLIC_GROQ_API_KEY=your-key-from-console.groq.com/keys
# Note it still ends up inlined in the built JS bundle, since this is a
# client-only app with no backend to hide it behind.

# Google Docs export (src/lib/googleDocs.js, Draft tab widget) uses Google
# Identity Services — a client-side-only OAuth flow, so unlike the Groq key
# above this ID is NOT a secret (same category as the Supabase key: it's
# meant to be public, and is only usable from origins you explicitly
# authorize in Google Cloud Console) and is safe to commit here directly.
#
# To enable it:
#   1. console.cloud.google.com -> create/select a project
#   2. APIs & Services -> Library -> enable "Google Docs API"
#   3. APIs & Services -> OAuth consent screen -> configure it (External is
#      fine for personal use; add yourself as a test user if it stays "in
#      testing")
#   4. APIs & Services -> Credentials -> Create Credentials -> OAuth client ID
#      -> Application type: Web application
#      -> Authorized JavaScript origins: add both
#           http://localhost:8081  (or whatever port `expo start --web` uses)
#           https://lilyelyseprichard.github.io
#      (no redirect URI needed — this uses the token flow, not the code flow)
#   5. Copy the client ID and set it below.
#   6. For the deployed GitHub Pages build, also add it as a repo secret
#      named GOOGLE_CLIENT_ID (Settings -> Secrets and variables -> Actions)
#      — the deploy workflow passes it through as this same env var.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=998024397856-qtjidu6pkfroc0us9i2sv2pihm2e8t90.apps.googleusercontent.com
